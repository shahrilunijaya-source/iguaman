# Laravel-in-public_html guard (Hostinger hPanel Git tool clones repo into doc root).
# Blocks sensitive files/source dirs, rewrites everything else into public/.

# Disable Apache content negotiation (MultiViews): it intercepts multi-segment URLs
# like /laporan/permohonan and returns 404 BEFORE the rewrite-into-public runs.
# Single-segment paths slip through, so report indexes worked but every detail 404'd.
# Also disable directory listings. (Laravel's public/.htaccess sets the same.)
Options -MultiViews -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block dotfiles (.env, .git, etc.)
    RewriteRule "(^|/)\." - [F,L]

    # Block project meta + config files at root
    RewriteRule "^(composer\.(json|lock)|package(-lock)?\.json|phpunit\.xml|artisan|deploy\.sh|.*\.md|tailwind\.config\.js|postcss\.config\.js|vite\.config\.js|webpack\.mix\.js)$" - [F,L]

    # Public docs pages (release notes + system overview) — served directly from docs/.
    # Carve-out MUST precede the docs/ block below, else [F] wins. Only these exact
    # files are exposed; the rest of docs/ (audit, design tokens) stays blocked.
    RewriteRule "^docs/(penambahbaikan-22|system-overview)\.html$" - [L]

    # Block Laravel source/runtime dirs
    RewriteRule "^(app|bootstrap|config|database|resources|routes|storage|tests|vendor|docs|source|node_modules)(/.*)?$" - [F,L]

    # Send everything else into public/
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
